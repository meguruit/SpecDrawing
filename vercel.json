{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "git lfs install --force && git lfs pull && npm install && (file -b public/assets/base/main/base_natural.jpg | grep -q JPEG || (echo 'LFS pull failed: base_natural.jpg is not a JPEG' >&2; exit 1))",
  "buildCommand": "next build",
  "headers": [
    {
      "source": "/assets/base/main/(mask_|shading_|base_).*\\.(png|jpg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/finishes/(.*)\\.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(catalog/finish-options\\.json|catalog/sheets\\.json|catalog/finish-options\\.warnings\\.json|assets/base/scenes\\.json|assets/base/main/scene\\.json|assets/base/main/parts\\.json)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
